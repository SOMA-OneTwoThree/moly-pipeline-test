# voice-harness 환경변수 예시 — 이 파일은 커밋됩니다. 실제 키는 .env에만 주입하세요.

# === moly-server (가운데 LLM 박스) ===
MOLY_SERVER_URL=http://localhost:3000/api/chat

# === provider 선택 (moly-server의 LLM_PROVIDER 추상화와 동일한 패턴) ===
# 나중에 다른 API 추가 시 여기 값만 바꿔 비교한다.
STT_PROVIDER=openai          # openai | mock
TTS_PROVIDER=openai          # openai | mock

# === OpenAI (STT + TTS 단일 키) ===
# OPENAI_API_KEY=   # 실제 키는 .env에만
STT_MODEL=gpt-4o-transcribe
STT_LANGUAGE=ko              # 입력 발화 언어 힌트(ko/en). 비우면 자동감지
TTS_MODEL=gpt-4o-mini-tts
TTS_VOICE=coral              # alloy|echo|fable|onyx|nova|shimmer|coral|sage|ash|ballad
TTS_FORMAT=pcm               # pcm(24kHz s16le, 최저지연) | wav | mp3
TTS_SPEED=1.2                # 말하는 빠르기 0.25~4.0 (tts-1 계열만). 1.0=기본, 1.2=약간 빠름

# === 출력 ===
OUT_DIR=runs                 # 메트릭 CSV/JSON, 합성 오디오 저장 위치
