# moly-server · LLM 파이프라인 환경변수 예시
# 이 파일은 커밋됩니다. 실제 시크릿(키)을 절대 여기에 적지 마세요.
# 실제 값은 gitignore된 로컬 `.env`에만 주입하세요.

# provider 선택 (stateless: anthropic|gemini|groq|openai|deepseek / stateful: letta)
LLM_PROVIDER=anthropic

# --- stateful(letta) provider 전용 ---
# LLM_PROVIDER=letta 일 때만 사용. Letta 서버가 페르소나·대화이력·장기메모리를 소유한다.
# LETTA_BASE_URL=http://localhost:8283
# LETTA_AGENT_ID=agent-...        # 기본 공유 agent. 요청 본문의 sessionId/agentId 로 턴별 오버라이드 가능.
# LETTA_API_KEY=                  # self-host SECURE 모드에서만 필요.

# 모델 / 최대 출력 토큰
LLM_MODEL=claude-sonnet-4-6
LLM_MAX_TOKENS=1024

# 시스템 프롬프트(미설정 시 코드 기본값 사용)
SYSTEM_PROMPT=

# Anthropic API 키 — 실행에 필수.
# 클론 후 이 파일을 .env로 복사하고 본인 키를 주입하세요. (실제 값은 .env에만)
# ANTHROPIC_API_KEY=

# 주의: 시크릿에 NEXT_PUBLIC_ 접두사 사용 금지(클라이언트 번들로 노출됨).
